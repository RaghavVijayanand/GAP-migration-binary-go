# gap_tool — .env configuration
# Copy this file to .env and fill in your values.

# ── Required ─────────────────────────────────────────────────────────
GAP_GRAFANA_URL=http://grafana:3000
GAP_GRAFANA_API_KEY=glsa_YOUR_SERVICE_ACCOUNT_TOKEN

GAP_PROMETHEUS_URL=http://prometheus:9090

GAP_HYPERDX_URL=http://hyperdx:8080
GAP_HYPERDX_API_KEY=YOUR_HYPERDX_API_KEY

# HyperDX metric source ID — required for dashboard and alert conversion.
# Leave blank to auto-discover from the API (first source is used).
GAP_METRIC_SOURCE_ID=

# ── Optional ─────────────────────────────────────────────────────────

# Alertmanager (skip if you don't use it)
GAP_ALERTMANAGER_URL=

# Webhook for alert notifications (auto-discovered if blank; omit if none).
GAP_WEBHOOK_ID=

# ── Backfill (only needed with --backfill) ────────────────────────────
GAP_CLICKHOUSE_HOST=localhost
GAP_CLICKHOUSE_PORT=8123
GAP_CLICKHOUSE_DATABASE=default
GAP_CLICKHOUSE_USERNAME=default
GAP_CLICKHOUSE_PASSWORD=

# Days of Prometheus history to pull (default: 3)
GAP_LOOKBACK_DAYS=3

# Range query step in seconds (default: 60)
GAP_STEP_SECONDS=60

# Rows per ClickHouse INSERT batch (default: 10000)
GAP_BATCH_SIZE=10000

# Regex to filter metric names (leave blank to use built-in defaults)
GAP_METRIC_FILTER=

# ServiceName tag written into every OTel row
GAP_SERVICE_NAME=prometheus-migrated
