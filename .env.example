# ─────────────────────────────────────────────────────────────────
# gap_tool — .env configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# ─────────────────────────────────────────────────────────────────

# ── Source: Grafana ──────────────────────────────────────────────
GAP_GRAFANA_URL=http://grafana:3000
GAP_GRAFANA_API_KEY=glsa_YOUR_SERVICE_ACCOUNT_TOKEN

# ── Source: Prometheus ───────────────────────────────────────────
GAP_PROMETHEUS_URL=http://prometheus:9090

# ── Source: Alertmanager (optional) ─────────────────────────────
GAP_ALERTMANAGER_URL=http://alertmanager:9093

# ── Target: HyperDX ─────────────────────────────────────────────
GAP_HYPERDX_URL=http://hyperdx:8080
GAP_HYPERDX_API_KEY=YOUR_HYPERDX_API_KEY

# HyperDX metric source ID — used to link chart series to the right
# data source. Find it in HyperDX under Settings → Sources.
GAP_METRIC_SOURCE_ID=YOUR_METRIC_SOURCE_ID

# HyperDX webhook ID for alert notifications (optional).
# Find it in HyperDX under Alerts → Webhooks.
GAP_WEBHOOK_ID=YOUR_WEBHOOK_ID

# ── ClickHouse (only needed if running --backfill) ───────────────
GAP_CLICKHOUSE_HOST=localhost
GAP_CLICKHOUSE_PORT=8123
GAP_CLICKHOUSE_DATABASE=default
GAP_CLICKHOUSE_USERNAME=default
GAP_CLICKHOUSE_PASSWORD=

# ── Backfill tuning ──────────────────────────────────────────────
# How many days of history to pull from Prometheus.
GAP_LOOKBACK_DAYS=3

# Prometheus range query resolution in seconds.
GAP_STEP_SECONDS=60

# Rows per ClickHouse INSERT batch.
GAP_BATCH_SIZE=10000

# Optional regex to only migrate matching metric names.
# Leave empty to use the default filter (skips scrape_*, ALERTS, up).
GAP_METRIC_FILTER=

# ServiceName tag written into every OTel row.
GAP_SERVICE_NAME=prometheus-migrated
